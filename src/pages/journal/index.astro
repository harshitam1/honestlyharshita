---
import Layout from '../../layouts/Layout.astro';
import { blogPosts, categories } from '../../data/blogData';
---

<Layout title="Journal - honestly, harshita" description="thoughts, stories, and the things i'm learning">
  <section class="min-h-screen py-10 bg-cream-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-6">
        <h1 class="font-serif text-4xl md:text-6xl font-bold text-navy-800 mb-6">
          My Journal
        </h1>
        <p class="text-xl text-navy-700 font-body max-w-2xl mx-auto">
          thoughts, stories, and the things i'm learning
        </p>
      </div>

      <!-- Categories -->
      <div class="mb-10">
        <div class="flex flex-wrap gap-3 justify-center">
          {categories.map((category) => (
            <div class="relative group">
              <button
                class={`category-card px-4 py-2 rounded-xl ${category.color} transition-all hover:shadow-md hover:-translate-y-0.5 cursor-pointer border-2 font-mono text-sm font-medium`}
                data-category={category.name}
              >
                {category.name}
                <span class="ml-1 opacity-60">({category.count})</span>
              </button>
              <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-56 px-3 py-2 bg-navy-800 text-cream-50 text-xs font-body rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none z-10 text-center leading-relaxed">
                {category.description}
                <div class="absolute top-full left-1/2 -translate-x-1/2 border-4 border-transparent border-t-navy-800"></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Blog Posts Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8" id="posts-grid">
        {blogPosts.map((post, index) => (
          <article
            class="post-card bg-white p-6 rounded-lg shadow-md hover:-translate-y-1 hover:shadow-lg transition-all duration-300 animate-fade-in"
            style={`animation-delay: ${index * 0.1}s`}
            data-categories={JSON.stringify(post.categories)}
          >
            <div class="flex items-center gap-2 text-sm text-navy-800 mb-4 font-sans">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
              </svg>
              <span>{post.readTime} min read</span>
              <span>•</span>
              <span>{new Date(post.date).toLocaleDateString('en-US', {
                month: 'short',
                day: 'numeric',
                year: 'numeric'
              })}</span>
              {post.pinned && (
                <>
                  <span>•</span>
                  <div class="flex items-center gap-1">
                    <svg class="w-3 h-3 text-cream-600" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 2C13.1 2 14 2.9 14 4V8H16C17.1 8 18 8.9 18 10V12H6V10C6 8.9 6.9 8 8 8H10V4C10 2.9 10.9 2 12 2M11 10V22H13V10H11Z"></path>
                    </svg>
                    <span class="text-xs font-mono text-cream-600 uppercase tracking-wide">Pinned</span>
                  </div>
                </>
              )}
            </div>

            <h2 class="font-serif text-2xl font-bold text-navy-800 mb-4 leading-tight">
              {post.title}
            </h2>

            <p class="text-navy-700 mb-6 leading-relaxed font-body">
              {post.excerpt}
            </p>

            <div class="flex flex-wrap gap-2 mb-6">
              {post.categories.map((category) => {
                const cat = categories.find(c => c.name === category);
                return (
                  <span class={`px-3 py-1 text-sm rounded-lg font-mono border ${cat?.color || 'bg-gray-100 text-gray-800'}`}>
                    {category}
                  </span>
                );
              })}
            </div>

            <a
              href={`/journal/${post.id}`}
              class="inline-flex items-center text-navy-800 font-mono font-medium hover:text-navy-900 transition-all duration-300"
            >
              Read more
              <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </article>
        ))}
      </div>

      {blogPosts.length === 0 && (
        <div class="text-center py-20">
          <p class="text-xl text-navy-700 font-body">No posts yet. Check back soon!</p>
        </div>
      )}
    </div>
  </section>
</Layout>

<script>
  const categoryCards = document.querySelectorAll('.category-card');
  const postCards = document.querySelectorAll<HTMLElement>('.post-card');
  let activeCategory: string | null = null;

  categoryCards.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.getAttribute('data-category');
      if (!category) return;

      // Toggle: if clicking the active category, deselect and show all
      if (activeCategory === category) {
        activeCategory = null;
        categoryCards.forEach(b => b.classList.remove('ring-4', 'ring-navy-800', 'ring-offset-2'));
        postCards.forEach(card => card.style.display = 'block');
        return;
      }

      activeCategory = category;

      // Update active state
      categoryCards.forEach(b => b.classList.remove('ring-4', 'ring-navy-800', 'ring-offset-2'));
      btn.classList.add('ring-4', 'ring-navy-800', 'ring-offset-2');

      // Filter posts
      postCards.forEach(card => {
        const categoriesAttr = card.getAttribute('data-categories');
        if (!categoriesAttr) return;
        const postCategories = JSON.parse(categoriesAttr);
        card.style.display = postCategories.includes(category) ? 'block' : 'none';
      });
    });
  });
</script>